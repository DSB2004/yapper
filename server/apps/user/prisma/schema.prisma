
generator client { 
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  moduleFormat  = "cjs"
}
datasource db {
   provider = "postgresql" 
}

model User {
  id         String   @id @default(uuid())
  publicId   String   @unique
  authId     String   @unique

  firstName  String
  lastName   String
  phone      String @unique
  avatar     String?
  bio         String?
  contacts   Contact[] @relation("OwnerUser")
  InContact  Contact[] @relation("ContactUser")

  adminAt        Group[]  @relation("GroupAdmin")
  participantAt  Group[]  @relation("GroupParticipant")

  groupsCreated  Group[] @relation("GroupCreated")
  groupsUpdated  Group[] @relation("GroupUpdated")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id        String @id @default(uuid())
  publicId  String @unique 

  chatroomId String


  contactId  String?  
  contact    User?  @relation("ContactUser", fields: [contactId], references: [id])
 
  isBlocked Boolean

  userId    String
  user      User   @relation("OwnerUser", fields: [userId], references: [id])

  phone     String? 
  name      String?


  @@unique([userId,phone])
}

model Group {
  id        String @id @default(uuid())
  publicId  String @unique 

  chatroomId String

  admins       User[] @relation("GroupAdmin")
  participants User[] @relation("GroupParticipant")

  name        String
  description String
  icon        String

  createdById String
  updatedById String

  createdBy User @relation("GroupCreated", fields: [createdById], references: [id])
  updatedBy User @relation("GroupUpdated", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}